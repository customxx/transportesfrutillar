---
---

<div class="sim-wrapper">
  <div class="sim-hero">
    <div>
      <h3>Simulador de Tarifa</h3>
      <p>Calcula el costo estimado de tu viaje en segundos</p>
    </div>
  </div>

  <div class="sim-body">
    <div class="sim-fields">
      <div class="sim-field sim-field-origin">
        <div class="sim-field-icon">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="3"/><circle cx="12" cy="12" r="10"/></svg>
        </div>
        <div class="sim-field-inputs">
          <label for="sim-origin">Origen</label>
          <input
            type="text"
            id="sim-origin"
            class="address-input sim-address-input"
            placeholder="¿Desde dónde sales?"
            autocomplete="off"
          />
        </div>
        <input type="hidden" id="sim-origin-coords" />
      </div>

      <button class="sim-swap-btn" id="sim-swap" title="Intercambiar origen y destino" type="button">
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M7 16V4M7 4L3 8M7 4l4 4M17 8v12M17 20l4-4M17 20l-4-4"/></svg>
      </button>

      <div class="sim-field sim-field-dest">
        <div class="sim-field-icon dest">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/></svg>
        </div>
        <div class="sim-field-inputs">
          <label for="sim-destination">Destino</label>
          <input
            type="text"
            id="sim-destination"
            class="address-input sim-address-input"
            placeholder="¿A dónde vas?"
            autocomplete="off"
          />
        </div>
        <input type="hidden" id="sim-destination-coords" />
      </div>
    </div>

    <div class="sim-result" id="sim-result" style="display: none;">
      <div class="sim-result-badge">
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
        Tarifa estimada
      </div>
      <div class="sim-result-row">
        <div class="sim-result-block">
          <span class="sim-result-label">Distancia</span>
          <span class="sim-result-value" id="sim-distancia">-- km</span>
        </div>
        <div class="sim-result-sep"></div>
        <div class="sim-result-block sim-result-block-price">
          <span class="sim-result-label">Precio</span>
          <span class="sim-result-value price" id="sim-precio">--</span>
        </div>
      </div>
    </div>

    <div class="sim-empty" id="sim-empty">
      <div class="sim-empty-icon">
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M12 8v4l3 3"/></svg>
      </div>
      <p>Ingresa origen y destino para ver la estimación</p>
    </div>
  </div>
</div>

<script>
  const TARIFA_POR_KM = 950;
  const FACTOR_CORRECCION = 1.3;
  const TARIFA_PLANA_KM = 6;
  const TARIFA_PLANA_PRECIO = 3500;

  function haversineDistance(lat1: number, lng1: number, lat2: number, lng2: number): number {
    const R = 6371;
    const dLat = ((lat2 - lat1) * Math.PI) / 180;
    const dLng = ((lng2 - lng1) * Math.PI) / 180;
    const a =
      Math.sin(dLat / 2) * Math.sin(dLat / 2) +
      Math.cos((lat1 * Math.PI) / 180) *
        Math.cos((lat2 * Math.PI) / 180) *
        Math.sin(dLng / 2) *
        Math.sin(dLng / 2);
    const c = 2 * Math.atan2(Math.sqrt(a), Math.sqrt(1 - a));
    return R * c;
  }

  async function geocodeAddress(address: string): Promise<{ lat: number; lng: number } | null> {
    const cacheKey = `geo_${address}`;
    const cached = sessionStorage.getItem(cacheKey);
    if (cached) {
      try {
        return JSON.parse(cached);
      } catch {
        sessionStorage.removeItem(cacheKey);
      }
    }
    const apiKey = (window as any).__googleMapsApiKey;
    if (!apiKey) return null;
    try {
      const res = await fetch(
        `https://maps.googleapis.com/maps/api/geocode/json?address=${encodeURIComponent(address)}&key=${apiKey}`
      );
      const data = await res.json();
      if (data.results?.[0]?.geometry?.location) {
        const coords = data.results[0].geometry.location;
        sessionStorage.setItem(cacheKey, JSON.stringify(coords));
        return coords;
      }
    } catch {}
    return null;
  }

  function parseCoords(coordsJson: string | null): { lat: number; lng: number } | null {
    if (!coordsJson) return null;
    try {
      const parsed = JSON.parse(coordsJson);
      if (parsed.lat != null && parsed.lng != null) return parsed;
    } catch {}
    return null;
  }

  function formatPrice(value: number): string {
    return '$' + value.toLocaleString('es-CL');
  }

  async function calculateSimulator() {
    const originInput = document.getElementById('sim-origin') as HTMLInputElement;
    const destInput = document.getElementById('sim-destination') as HTMLInputElement;
    const originCoordsField = document.getElementById('sim-origin-coords') as HTMLInputElement;
    const destCoordsField = document.getElementById('sim-destination-coords') as HTMLInputElement;
    const resultDiv = document.getElementById('sim-result') as HTMLDivElement;
    const emptyDiv = document.getElementById('sim-empty') as HTMLDivElement;
    const distanciaEl = document.getElementById('sim-distancia') as HTMLSpanElement;
    const precioEl = document.getElementById('sim-precio') as HTMLSpanElement;

    const origin = originInput?.value.trim();
    const destination = destInput?.value.trim();

    if (!origin || !destination) {
      resultDiv.style.display = 'none';
      emptyDiv.style.display = 'flex';
      return;
    }

    const originCoords = parseCoords(originCoordsField?.value ?? null);
    const destCoords = parseCoords(destCoordsField?.value ?? null);

    let originLatLng = originCoords;
    let destLatLng = destCoords;

    if (!originLatLng) originLatLng = await geocodeAddress(origin);
    if (!destLatLng) destLatLng = await geocodeAddress(destination);

    if (!originLatLng || !destLatLng) {
      resultDiv.style.display = 'none';
      emptyDiv.style.display = 'flex';
      emptyDiv.querySelector('p')!.textContent = 'No pudimos calcular la ruta. Verifica las direcciones.';
      return;
    }

    const raw = haversineDistance(
      originLatLng.lat,
      originLatLng.lng,
      destLatLng.lat,
      destLatLng.lng
    );
    const distanciaKm = Math.round(raw * FACTOR_CORRECCION * 10) / 10;
    const precioEstimado = distanciaKm <= TARIFA_PLANA_KM
      ? TARIFA_PLANA_PRECIO
      : Math.round(distanciaKm * TARIFA_POR_KM);

    distanciaEl.textContent = `~${distanciaKm} km`;
    precioEl.textContent = formatPrice(precioEstimado);

    emptyDiv.style.display = 'none';
    resultDiv.style.display = 'block';
  }

  let debounceTimer: ReturnType<typeof setTimeout>;

  function initSimulator() {
    const originInput = document.getElementById('sim-origin') as HTMLInputElement;
    const destInput = document.getElementById('sim-destination') as HTMLInputElement;
    const swapBtn = document.getElementById('sim-swap') as HTMLButtonElement;

    if (!originInput || !destInput) return;

    const triggerCalc = () => {
      clearTimeout(debounceTimer);
      debounceTimer = setTimeout(calculateSimulator, 600);
    };

    originInput.addEventListener('input', triggerCalc);
    destInput.addEventListener('input', triggerCalc);

    swapBtn?.addEventListener('click', () => {
      const tmp = originInput.value;
      originInput.value = destInput.value;
      destInput.value = tmp;

      const tmpCoords = (document.getElementById('sim-origin-coords') as HTMLInputElement)?.value;
      const destCoordsEl = document.getElementById('sim-destination-coords') as HTMLInputElement;
      const originCoordsEl = document.getElementById('sim-origin-coords') as HTMLInputElement;
      if (originCoordsEl && destCoordsEl) {
        const tmpCoordsDest = destCoordsEl.value;
        destCoordsEl.value = tmpCoords;
        originCoordsEl.value = tmpCoordsDest;
      }

      calculateSimulator();
    });

    if ((window as any).__googleMapsApiKey && (window as any).google?.maps?.places) {
      (window as any).__initAutocompleteForSimulator();
    }
  }

  (window as any).__initAutocompleteForSimulator = () => {
    const originInput = document.getElementById('sim-origin') as HTMLInputElement;
    const destInput = document.getElementById('sim-destination') as HTMLInputElement;
    const originCoordsField = document.getElementById('sim-origin-coords') as HTMLInputElement;
    const destCoordsField = document.getElementById('sim-destination-coords') as HTMLInputElement;

    const setup = (input: HTMLInputElement | null, coordsField: HTMLInputElement | null) => {
      if (!input || !coordsField) return;
      // @ts-ignore - google is loaded from Google Maps API
      const autocomplete = new google.maps.places.Autocomplete(input, {
        componentRestrictions: { country: 'cl' },
        fields: ['formatted_address', 'geometry'],
      });
      autocomplete.addListener('place_changed', () => {
        const place = autocomplete.getPlace();
        if (place.formatted_address) {
          input.value = place.formatted_address;
        }
        if (place.geometry?.location) {
          coordsField.value = JSON.stringify({
            lat: place.geometry.location.lat(),
            lng: place.geometry.location.lng(),
          });
        }
        calculateSimulator();
      });
    };

    setup(originInput, originCoordsField);
    setup(destInput, destCoordsField);
  };

  document.addEventListener('DOMContentLoaded', () => {
    initSimulator();
  });

  document.addEventListener('astro:after-swap', () => {
    initSimulator();
  });
</script>

<style>
  .sim-wrapper {
    background: var(--color-white);
    border-radius: 20px;
    box-shadow: 0 4px 24px rgba(0, 0, 0, 0.08), 0 1px 4px rgba(0, 0, 0, 0.04);
    overflow: hidden;
    width: 100%;
    border: 1px solid rgba(0, 0, 0, 0.05);
  }

  .sim-hero {
    background: linear-gradient(135deg, var(--color-primary), var(--color-primary-dark));
    color: var(--color-white);
    padding: 1.375rem 1.5rem;
    display: flex;
    align-items: center;
    gap: 1rem;
  }

  .sim-hero-icon {
    width: 48px;
    height: 48px;
    min-width: 48px;
    background: rgba(255, 255, 255, 0.2);
    border-radius: 14px;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .sim-hero h3 {
    font-size: 1.1rem;
    font-weight: 700;
    margin-bottom: 0.15rem;
  }

  .sim-hero p {
    font-size: 0.8rem;
    opacity: 0.85;
    line-height: 1.3;
  }

  .sim-body {
    padding: 1.25rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .sim-fields {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    gap: 0.5rem;
  }

  .sim-field {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .sim-field-icon {
    width: 28px;
    height: 28px;
    border-radius: 8px;
    background: var(--color-primary-light);
    color: var(--color-primary);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .sim-field-icon.dest {
    background: #fef3c7;
    color: #d97706;
  }

  .sim-field-inputs {
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
  }

  .sim-field-inputs label {
    font-size: 0.72rem;
    font-weight: 700;
    color: var(--color-gray-500);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    padding-left: 0.15rem;
  }

  .sim-address-input {
    padding: 0.75rem 1rem;
    border: 1.5px solid var(--color-gray-200);
    border-radius: 12px;
    font-size: 0.9rem;
    font-family: inherit;
    color: var(--color-dark);
    background: var(--color-white);
    transition: border-color 0.2s, box-shadow 0.2s;
    width: 100%;
  }

  .sim-address-input:focus {
    outline: none;
    border-color: var(--color-primary);
    box-shadow: 0 0 0 4px rgba(37, 99, 235, 0.08);
  }

  .sim-address-input::placeholder {
    color: var(--color-gray-400);
    font-size: 0.875rem;
  }

  .sim-swap-btn {
    width: 40px;
    height: 40px;
    border-radius: 50%;
    border: 1.5px solid var(--color-gray-200);
    background: var(--color-white);
    color: var(--color-gray-500);
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: all 0.2s;
    flex-shrink: 0;
    margin-top: 1.4rem;
  }

  .sim-swap-btn:hover {
    background: var(--color-primary-light);
    border-color: var(--color-primary);
    color: var(--color-primary);
    transform: rotate(180deg);
  }

  .sim-result {
    background: linear-gradient(135deg, #f0f5ff 0%, #eef2ff 100%);
    border: 1.5px solid #dde5ff;
    border-radius: 16px;
    padding: 1rem 1.25rem;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .sim-result-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    background: var(--color-primary);
    color: var(--color-white);
    padding: 0.3rem 0.75rem;
    border-radius: 9999px;
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    align-self: flex-start;
  }

  .sim-result-row {
    display: flex;
    align-items: center;
    gap: 1rem;
  }

  .sim-result-block {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
  }

  .sim-result-label {
    font-size: 0.72rem;
    font-weight: 600;
    color: var(--color-gray-500);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .sim-result-value {
    font-size: 1.35rem;
    font-weight: 800;
    color: var(--color-dark);
    line-height: 1.2;
  }

  .sim-result-value.price {
    color: var(--color-primary);
    font-size: 1.5rem;
  }

  .sim-result-sep {
    width: 1px;
    height: 44px;
    background: #dde5ff;
    flex-shrink: 0;
  }

  .sim-empty {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.6rem;
    padding: 1.25rem;
    text-align: center;
    color: var(--color-gray-400);
  }

  .sim-empty-icon {
    width: 48px;
    height: 48px;
    border-radius: 50%;
    background: var(--color-gray-100);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color-gray-400);
  }

  .sim-empty p {
    font-size: 0.875rem;
    color: var(--color-gray-400);
    line-height: 1.4;
  }

  @media (max-width: 480px) {
    .sim-hero {
      padding: 1.125rem 1.25rem;
      gap: 0.875rem;
    }

    .sim-hero-icon {
      width: 42px;
      height: 42px;
      min-width: 42px;
      border-radius: 12px;
    }

    .sim-hero h3 {
      font-size: 1rem;
    }

    .sim-hero p {
      font-size: 0.75rem;
    }

    .sim-body {
      padding: 1rem;
      gap: 0.875rem;
    }

    .sim-address-input {
      padding: 0.7rem 0.875rem;
      font-size: 0.875rem;
      border-radius: 10px;
    }

    .sim-field-icon {
      width: 26px;
      height: 26px;
      border-radius: 7px;
    }

    .sim-swap-btn {
      width: 36px;
      height: 36px;
      margin-top: 1.25rem;
    }

    .sim-result {
      padding: 0.875rem 1rem;
      border-radius: 14px;
    }

    .sim-result-value {
      font-size: 1.2rem;
    }

    .sim-result-value.price {
      font-size: 1.3rem;
    }

    .sim-empty-icon {
      width: 42px;
      height: 42px;
    }
  }

  @media (min-width: 600px) {
    .sim-hero {
      padding: 1.5rem 1.75rem;
    }

    .sim-body {
      padding: 1.5rem;
    }

    .sim-swap-btn {
      margin-top: 1.6rem;
    }

    .sim-result {
      padding: 1.25rem 1.5rem;
    }

    .sim-result-value {
      font-size: 1.5rem;
    }

    .sim-result-value.price {
      font-size: 1.7rem;
    }
  }
</style>